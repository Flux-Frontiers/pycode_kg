{
  "mcpServers": {
    "pycodekg_pycodekg": {
      "command": "/absolute/path/to/.venv/bin/pycodekg-mcp",
      "args": [
        "--repo",
        "/absolute/path/to/repo",
        "--db",
        "/absolute/path/to/repo/.pycodekg/pycodekg.sqlite",
        "--lancedb",
        "/absolute/path/to/repo/.pycodekg/lancedb"
      ]
    },
    "dockg_pycodekg": {
      "command": "/absolute/path/to/.venv/bin/dockg-mcp",
      "args": [
        "--repo",
        "/absolute/path/to/repo",
        "--db",
        "/absolute/path/to/repo/.dockg/pycodekg.sqlite",
        "--lancedb",
        "/absolute/path/to/repo/.dockg/lancedb"
      ]
    }
  }
}
